  "changelog.item3Copy": "\u0905\u092c tasks \u0914\u0930 journal global search, quick add, activity feed, diagnostics \u0914\u0930 CSV backup/import \u092e\u0947\u0902 \u092d\u0940 \u0915\u093e\u092e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964",
