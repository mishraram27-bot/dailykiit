  "changelog.title": "v9.8 \u092e\u0947\u0902 \u0915\u094d\u092f\u093e \u0928\u092f\u093e \u0939\u0948",
  "changelog.item1Title": "\u0926\u093f\u0928 \u0915\u0947 \u091f\u093e\u0938\u094d\u0915",
  "changelog.item1Copy": "DailyKit \u0905\u092c \u090f\u0915 \u0938\u0930\u0932 today list \u0926\u0947\u0924\u093e \u0939\u0948 \u091c\u093f\u0938\u0938\u0947 \u091d\u091f\u092a\u091f task capture \u0914\u0930 completion \u0909\u0938\u0940 offline workspace \u092e\u0947\u0902 \u0930\u0939\u0924\u0947 \u0939\u0948\u0902\u0964",
  "changelog.item2Title": "\u0921\u0947\u0932\u0940 \u091c\u0930\u094d\u0928\u0932",
  "changelog.item2Copy": "\u090f\u0915 \u0928\u092f\u093e journal tool \u0906\u092a\u0915\u094b \u0926\u0948\u0928\u093f\u0915 reflections, mood \u0914\u0930 short notes \u0938\u0947\u0935 \u0915\u0930\u0928\u0947 \u0926\u0947\u0924\u093e \u0939\u0948\u0964",
